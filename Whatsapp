sap.ui.define([
    "project1/controller/BaseController",
    "sap/ui/model/json/JSONModel"
], function (BaseController, JSONModel) {
    "use strict";

    var BAR_METRICS  = ["NII","NFI","TotalIncome","Cost","Impairments","OperatingProfit","FundedAssets","FundedLiabilities","RWA"];
    var LINE_METRICS = ["RoTE","JAWS","CIR"];
    var ALL_METRICS  = BAR_METRICS.concat(LINE_METRICS);
    var SERIES       = ["pyActuals","actuals2026","outlook2026","br2026"];
    var Q_CATS       = ["Q1'25","Q2'25","Q3'25","Q4'25","Q1'26","Q2'26","Q3'26","Q4'26","FY'25","FY'26"];
    var H_CATS       = ["H1'25","H2'25","H1'26","H2'26","FY'25","FY'26"];

    return BaseController.extend("project1.controller.Trends", {

        onInit: function () {
            this.getOwnerComponent().getRouter()
                .getRoute("trends")
                .attachPatternMatched(this._onTrendsMatched, this);
        },

        _onTrendsMatched: function () {
            var oView  = this.getView();

            // _getStore() returns the COMPONENT-level shared model.
            // If View1 already created it (user navigated from Overview),
            // this returns the exact same object — selectedTop is preserved.
            // If this is the first page ever opened, it creates it fresh.
            var oStore = this._getStore();

            // Only update selectedSub to show "Trends" in the title.
            // selectedTop is NOT touched — it keeps whatever Group/CIB/WRB
            // the user last selected on either page.
            oStore.setProperty("/state/selectedSub", "Trends");

            if (!oStore.getProperty("/state/period")) {
                oStore.setProperty("/state/period", "quarterly");
            }

            // Attach the shared model to this view so XML bindings work
            if (!oView.getModel("store")) {
                oView.setModel(oStore, "store");
            }

            this._refreshNavToggles();
            this._loadTrendsData();
        },

        // ── Nav toggles ───────────────────────────────────────
        _refreshNavToggles: function () {
            var s = this._getState();
            this._applyToggles({
                trends_groupToggle:    s.selectedTop === "Group",
                trends_CIBtoggle:      s.selectedTop === "CIB",
                trends_WRBtoggle:      s.selectedTop === "WRB",
                trends_overviewToggle: s.selectedSub === "Overview",
                trends_trendsToggle:   s.selectedSub === "Trends",
                trends_btnM:           s.unit        === "$m",
                trends_btnBn:          s.unit        === "$bn",
                trends_btnRFX:         s.currency    === "RFX",
                trends_btnCFX:         s.currency    === "CFX",
                tr_btnM:               s.period      === "monthly",
                tr_btnBn:              s.period      === "quarterly",
                trtnBn:                s.period      === "halfYearly"
            });
        },

        // ── Nav handlers ──────────────────────────────────────
        onPageSelect: function (oEvent) {
            this._getStore().setProperty("/state/selectedTop", oEvent.getSource().getText());
            this._refreshNavToggles();
            this._disposeAllCharts();
            this._loadTrendsData();
        },

        onSubPageSelect: function (oEvent) {
            this._getStore().setProperty("/state/selectedSub", oEvent.getSource().getText());
            this._refreshNavToggles();
        },

        oncustomToggleClick: function (oEvent) {
            var sText  = oEvent.getSource().getText();
            var oStore = this._getStore();
            var bPeriod = sText === "Monthly" || sText === "Quarterly" || sText === "Half Yearly";

            if (sText === "$m"  || sText === "$bn")  { oStore.setProperty("/state/unit",     sText); this._loadTrendsData(); }
            if (sText === "RFX" || sText === "CFX")  { oStore.setProperty("/state/currency", sText); this._loadTrendsData(); }
            if (sText === "Monthly")     oStore.setProperty("/state/period", "monthly");
            if (sText === "Quarterly")   oStore.setProperty("/state/period", "quarterly");
            if (sText === "Half Yearly") oStore.setProperty("/state/period", "halfYearly");

            this._refreshNavToggles();
            if (bPeriod) this._renderAllCharts();
        },

        onOverviewNavigate: function () {
            // Update the shared model before navigating so View1 sees
            // the correct selectedTop immediately — no reset, no new model.
            this._getStore().setProperty("/state/selectedSub", "Overview");
            this._disposeAllCharts();
            this.getOwnerComponent().getRouter().navTo("overview");
        },

        // ── Load from HANA ────────────────────────────────────
        _loadTrendsData: function () {
            var that = this;
            this._oDataFetch(this._getTrendsFilter(), "trendMetricName asc,trendPeriodIndex asc")
                .then(function (aRows) {
                    that._data = that._buildPeriodData(aRows);
                    setTimeout(function () { that._loadEChartsAndRender(); }, 150);
                })
                .catch(function (e) { console.error("[Trends]", e); });
        },

        _getTrendsFilter: function () {
            var s = this._getState();
            return "recordType eq 'TRENDS' and topGroup eq '" + s.selectedTop +
                   "' and pageView eq 'Trends' and displayUnit eq '" + s.unit +
                   "' and currencyType eq '" + s.currency + "'";
        },

        // ── Build { monthly, quarterly, halfYearly } ──────────
        _buildPeriodData: function (aRows) {
            var oMonthly = { categories: [] };
            ALL_METRICS.forEach(function (m) {
                oMonthly[m] = {};
                SERIES.forEach(function (s) { oMonthly[m][s] = []; });
            });

            var oQ = { categories: Q_CATS };
            ALL_METRICS.forEach(function (m) {
                oQ[m] = {};
                SERIES.forEach(function (s) { oQ[m][s] = new Array(10).fill(null); });
            });
            aRows.forEach(function (r) {
                var aS = oQ[r.trendMetricName] && oQ[r.trendMetricName][r.trendSeriesType];
                if (aS && r.trendPeriodIndex >= 0 && r.trendPeriodIndex < 10) {
                    aS[r.trendPeriodIndex] = r.trendDataValue;
                }
            });

            var that = this;
            var oH = { categories: H_CATS };
            ALL_METRICS.forEach(function (m) {
                var bLine = LINE_METRICS.indexOf(m) !== -1;
                var q = oQ[m];
                oH[m] = {};
                SERIES.forEach(function (s) {
                    var a = q[s];
                    oH[m][s] = [
                        that._combine(a[0], a[1], bLine),
                        that._combine(a[2], a[3], bLine),
                        that._combine(a[4], a[5], bLine),
                        that._combine(a[6], a[7], bLine),
                        a[8], a[9]
                    ];
                });
            });

            return { monthly: oMonthly, quarterly: oQ, halfYearly: oH };
        },

        _combine: function (a, b, bAvg) {
            if (a === null && b === null) return null;
            if (a === null) return b;
            if (b === null) return a;
            return bAvg ? +((a + b) / 2).toFixed(2) : a + b;
        },

        // ── ECharts ───────────────────────────────────────────
        _loadEChartsAndRender: function () {
            if (window.echarts) { this._renderAllCharts(); return; }
            var s = document.createElement("script");
            s.src = "https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js";
            s.onload = this._renderAllCharts.bind(this);
            document.head.appendChild(s);
        },

        _renderAllCharts: function () {
            if (!this._data) return;
            var s = this._getState().period || "quarterly";
            var d = this._data[s];
            if (!d) return;
            var c = d.categories;
            BAR_METRICS.forEach(function (m) { this._renderBarChart("chart" + m, c, d[m]); }, this);
            LINE_METRICS.forEach(function (m) { this._renderLineChart("chart" + m, c, d[m]); }, this);
        },

        _getDomId:  function (id) { return this.getView().getId() + "--" + id; },

        _initChart: function (id) {
            var oDom = document.getElementById(this._getDomId(id));
            if (!oDom) return null;
            var oEx = window.echarts.getInstanceByDom(oDom);
            if (oEx) oEx.dispose();
            var oC = echarts.init(oDom);
            window.addEventListener("resize", function () { oC.resize(); });
            return oC;
        },

        _disposeAllCharts: function () {
            var that = this;
            ["chartNII","chartNFI","chartTotalIncome","chartCost","chartImpairments",
             "chartOperatingProfit","chartFundedAssets","chartFundedLiabilities","chartRWA",
             "chartRoTE","chartJAWS","chartCIR"].forEach(function (id) {
                var d = document.getElementById(that._getDomId(id));
                if (d) { var i = window.echarts.getInstanceByDom(d); if (i) i.dispose(); }
            });
        },

        _noDataOption: function () {
            return { title: { text: "No data available", left: "center", top: "center", textStyle: { fontSize: 11, color: "#999" } } };
        },

        _renderBarChart: function (id, cats, d) {
            var oC = this._initChart(id);
            if (!oC) return;
            if (!d || !cats || !cats.length) { oC.setOption(this._noDataOption()); return; }

            var DATA = cats.map(function (c, i) {
                if (d.pyActuals[i]   != null) return { value: d.pyActuals[i],   itemStyle: { color: "#cccccc" }, seriesName: "PY Actuals" };
                if (d.actuals2026[i] != null) return { value: d.actuals2026[i], itemStyle: { color: "#1a5fa8" }, seriesName: "2026 Actuals" };
                if (d.outlook2026[i] != null) return { value: d.outlook2026[i], itemStyle: { color: "#5bc4f5" }, seriesName: "2026 Outlook" };
                return { value: null, itemStyle: { color: "transparent" } };
            });

            oC.setOption({
                animation: false,
                grid: { left: 10, right: 10, top: 35, bottom: 45, containLabel: true },
                legend: { show: false },
                xAxis: { type: "category", data: cats, axisLine: { lineStyle: { color: "#ccc" } }, axisTick: { show: false }, axisLabel: { fontSize: 9, interval: 0, color: function (v) { return v === "" ? "transparent" : v.includes("'25") ? "#999" : "#333"; } } },
                yAxis: { type: "value", axisLabel: { show: false }, splitLine: { show: false }, axisLine: { show: false }, axisTick: { show: false } },
                tooltip: { trigger: "axis", formatter: function (p) { var x = p[0]; return x && x.value != null ? x.name + "<br/>" + x.marker + " " + (x.data.seriesName || "") + ": " + x.value : ""; }, textStyle: { fontSize: 10 } },
                series: [
                    { type: "bar", data: DATA, barCategoryGap: "40%", label: { show: true, position: "top", fontSize: 8, color: "#555", formatter: function (p) { return p.value != null ? p.value : ""; } } },
                    { type: "line", data: d.br2026, showSymbol: true, symbol: "circle", symbolSize: 4, lineStyle: { color: "#27ae60", width: 2 }, itemStyle: { color: "#27ae60" }, connectNulls: false, label: { show: false } }
                ]
            });
        },

        _renderLineChart: function (id, cats, d) {
            var oC = this._initChart(id);
            if (!oC) return;
            if (!d || !cats || !cats.length) { oC.setOption(this._noDataOption()); return; }

            var fmt = function (p) { return p.value != null ? p.value : ""; };
            var xCol = function (v) { return v.includes("'25") ? "#999" : "#333"; };

            oC.setOption({
                animation: false,
                grid: { left: 10, right: 10, top: 35, bottom: 45, containLabel: true },
                legend: { show: false },
                xAxis: { type: "category", data: cats, axisLine: { lineStyle: { color: "#ccc" } }, axisTick: { show: false }, axisLabel: { fontSize: 9, interval: 0, color: xCol } },
                yAxis: { type: "value", axisLabel: { show: false }, splitLine: { show: false }, axisLine: { show: false }, axisTick: { show: false } },
                tooltip: { trigger: "axis", textStyle: { fontSize: 10 } },
                series: [
                    { name: "PY Actuals",   type: "line", data: d.pyActuals,   symbol: "circle", symbolSize: 4, lineStyle: { color: "#cccccc", width: 2 }, itemStyle: { color: "#cccccc" }, connectNulls: false, label: { show: true, fontSize: 8, color: "#999",   position: "bottom", formatter: fmt } },
                    { name: "2026 Actuals", type: "line", data: d.actuals2026.map(function (v, i) { return v == null && d.outlook2026[i] != null ? d.outlook2026[i] : v; }), symbol: "circle", symbolSize: 4, lineStyle: { color: "#1a5fa8", width: 2 }, itemStyle: { color: "#1a5fa8" }, connectNulls: false, label: { show: true, fontSize: 8, color: "#1a5fa8", position: "bottom", formatter: fmt } },
                    { name: "2026 BR",      type: "line", data: d.br2026,      symbol: "circle", symbolSize: 4, lineStyle: { color: "#27ae60", width: 2 }, itemStyle: { color: "#27ae60" }, connectNulls: false, label: { show: true, fontSize: 8, color: "#27ae60", position: "top",    formatter: fmt } }
                ]
            });
        }
    });
});

