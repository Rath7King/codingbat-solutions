sap.ui.define([
    "project1/controller/BaseController",
    "sap/ui/model/json/JSONModel",
    "sap/ui/core/Fragment"
], function (BaseController, JSONModel, Fragment) {
    "use strict";

    return BaseController.extend("project1.controller.View1", {

        onInit: function () {
            this.getOwnerComponent().getRouter()
                .getRoute("overview")
                .attachPatternMatched(this._onOverviewMatched, this);
        },

        _onOverviewMatched: function () {
            var oView  = this.getView();

            // _getStore() returns the COMPONENT-level shared model.
            // It creates it once on the very first call (ever, for any page).
            // On every subsequent call — from this page OR from Trends —
            // it returns the exact same object. selectedTop is never reset.
            var oStore = this._getStore();

            // Only update selectedSub so we show "Overview" in the title.
            // selectedTop stays whatever it was — Group, CIB, or WRB.
            oStore.setProperty("/state/selectedSub", "Overview");

            // The view inherits the component model automatically
            // via UI5 model propagation — no need to setModel on the view.
            // But we still call it so XML bindings using {store>...} work
            // immediately on first render (belt-and-suspenders).
            if (!oView.getModel("store")) {
                oView.setModel(oStore, "store");
            }

            this._refreshNavToggles();
            this._updateGrid();
            this._loadChartAndTableData();
        },

        // ── Nav toggles ───────────────────────────────────────
        _refreshNavToggles: function () {
            var s = this._getState();
            this._applyToggles({
                groupToggle:    s.selectedTop === "Group",
                CIBtoggle:      s.selectedTop === "CIB",
                WRBtoggle:      s.selectedTop === "WRB",
                overviewToggle: s.selectedSub === "Overview",
                trendsToggle:   s.selectedSub === "Trends",
                btnM:           s.unit        === "$m",
                btnBn:          s.unit        === "$bn",
                btnRFX:         s.currency    === "RFX",
                btnCFX:         s.currency    === "CFX"
            });
        },

        // ── Nav handlers ──────────────────────────────────────
        onPageSelect: function (oEvent) {
            this._getStore().setProperty("/state/selectedTop", oEvent.getSource().getText());
            this._refreshNavToggles();
            this._updateGrid();
            this._loadChartAndTableData();
        },

        onSubPageSelect: function (oEvent) {
            this._getStore().setProperty("/state/selectedSub", oEvent.getSource().getText());
            this._refreshNavToggles();
            this._updateGrid();
        },

        oncustomToggleClick: function (oEvent) {
            var sText  = oEvent.getSource().getText();
            var oStore = this._getStore();
            if (sText === "$m" || sText === "$bn")   oStore.setProperty("/state/unit",     sText);
            if (sText === "RFX" || sText === "CFX")  oStore.setProperty("/state/currency", sText);
            this._refreshNavToggles();
            this._updateGrid();
            this._loadChartAndTableData();
        },

        onTrendsNavigate: function () {
            // Update the shared model before navigating so Trends sees
            // the correct selectedTop and selectedSub immediately
            this._getStore().setProperty("/state/selectedSub", "Trends");
            this._refreshNavToggles();
            this.getOwnerComponent().getRouter().navTo("trends");
        },

        // ── Widget cards ──────────────────────────────────────
        _updateGrid: function () {
            var oContainer = this.byId("mainCardsContainer");
            if (!oContainer) return;
            oContainer.destroyItems();

            this._oDataFetch(this._getStateFilter("WIDGET"), "kpiDisplayOrder asc")
                .then(function (aRows) {
                    if (!aRows.length) return;
                    var aCards = aRows.map(function (r) {
                        return {
                            title: r.kpiTitle,          primaryValue: r.ytdActualValue,
                            primaryPercent: r.ytdYoyPercent, isNegative: r.ytdIsNegative,
                            dir1: r.ytdYoyArrowUp,      subLabel: r.ytdLabel,
                            subLabelYOY: r.ytdYoyLabel,
                            row1Label: r.vsBudgetLabel,  row1Value: r.vsBudgetValue,
                            row2Label: r.pqtdLabel,      row2LabelYOY: r.pqtdYoyLabel,
                            row2Value: r.pqtdValue,      row2Percent: r.pqtdYoyPercent,
                            dir2: r.pqtdArrowUp,         row2IsNegative: r.pqtdIsNegative,
                            row3Label: r.fyOutlookLabel, row3LabelYOY: r.fyOutlookYoyLabel,
                            row3Value: r.fyOutlookValue, row3Percent: r.fyOutlookYoyPercent,
                            dir3: r.fyOutlookArrowUp,    row3IsNegative: r.fyOutlookIsNegative
                        };
                    });

                    if (!this._oKpiCardTemplate) {
                        Fragment.load({ name: "project1.view.fragments.KpiCard", controller: this })
                            .then(function (oFrag) {
                                this._oKpiCardTemplate = oFrag;
                                this._createCardsFromTemplate(aCards, oContainer);
                            }.bind(this));
                    } else {
                        this._createCardsFromTemplate(aCards, oContainer);
                    }
                }.bind(this))
                .catch(function (e) { console.error("[View1] Widgets:", e); });
        },

        _createCardsFromTemplate: function (aCards, oContainer) {
            aCards.forEach(function (oData, i) {
                var oCard = this._oKpiCardTemplate.clone("kpiCard_" + i);
                oCard.setModel(new JSONModel(oData), "card");
                oContainer.addItem(oCard);
            }, this);
        },

        // ── Chart + Table ─────────────────────────────────────
        _loadChartAndTableData: function () {
            var that = this;
            Promise.all([
                this._oDataFetch(this._getStateFilter("CHART"), "productDisplayOrder asc"),
                this._oDataFetch(this._getStateFilter("TABLE"), "clusterHierarchyLevel asc,parentClusterName asc,clusterName asc")
            ]).then(function (aRes) {
                var oChartModel = that.getView().getModel("chartStore") || new JSONModel();
                oChartModel.setData({
                    chartData: aRes[0].map(function (r) {
                        return { product: r.productName, fyOutlook: r.productFyOutlook, ytd: r.productYtdActual, fyBudget: r.productFyBudget };
                    }),
                    tableData: that._buildTableTree(aRes[1])
                });
                that.getView().setModel(oChartModel, "chartStore");
                that._chartData = oChartModel.getData().chartData;
                setTimeout(function () { that._loadAndRenderECharts(); }, 150);
            }).catch(function (e) { console.error("[View1] Chart/Table:", e); });
        },

        _buildTableTree: function (aRows) {
            function mapRow(r) {
                return { cluster: r.clusterName, ytd: r.clusterYtdActual, yoy: r.clusterYoyPercent, qtd: r.clusterQtdOutlook, fyOutlook: r.clusterFyOutlook };
            }
            var oRoot = aRows.find(function (r) { return r.clusterHierarchyLevel === 0; });
            var aL1   = aRows.filter(function (r) { return r.clusterHierarchyLevel === 1; });
            var aL2   = aRows.filter(function (r) { return r.clusterHierarchyLevel === 2; });
            if (!oRoot) return [];

            var oBuilt = mapRow(oRoot);
            oBuilt.children = aL1.map(function (l1) {
                var oNode = mapRow(l1);
                var aKids = aL2.filter(function (l2) { return l2.parentClusterName === l1.clusterName; }).map(mapRow);
                if (aKids.length) oNode.children = aKids;
                return oNode;
            });
            return [oBuilt];
        },

        // ── ECharts ───────────────────────────────────────────
        _loadAndRenderECharts: function () {
            if (window.echarts) { this._renderChart(); return; }
            var s = document.createElement("script");
            s.src = "https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js";
            s.onload = this._renderChart.bind(this);
            document.head.appendChild(s);
        },

        _renderChart: function () {
            var sDomId = this.getView().getId() + "--echartsContainer";
            var oDom   = document.getElementById(sDomId);
            if (!oDom || !this._chartData) return;

            var oExist = window.echarts.getInstanceByDom(oDom);
            if (oExist) oExist.dispose();

            var oChart = echarts.init(oDom);
            var aData  = this._chartData;

            function fmt(v) {
                if (v === 0) return "0";
                var a = Math.abs(v), s = v < 0 ? "-" : "";
                if (a >= 1e9) return s + (a / 1e9).toFixed(3).replace(/\.?0+$/, "") + "B";
                if (a >= 1e6) return s + (a / 1e6).toFixed(3).replace(/\.?0+$/, "") + "M";
                return s + a.toLocaleString();
            }

            oChart.setOption({
                backgroundColor: "#ffffff",
                legend: { top: 0, right: 0, itemWidth: 12, itemHeight: 12, textStyle: { fontSize: 11, color: "#333" }, data: [{ name: "FY Outlook", icon: "rect" }, { name: "YTD", icon: "rect" }, { name: "FY Budget", icon: "rect" }] },
                grid:  { left: 60, right: 20, top: 40, bottom: 50 },
                xAxis: { type: "category", data: aData.map(function (d) { return d.product; }), axisLine: { lineStyle: { color: "#ccc" } }, axisTick: { show: false }, axisLabel: { color: "#555", fontSize: 11 } },
                yAxis: { type: "value", axisLabel: { color: "#555", fontSize: 10, formatter: fmt }, splitLine: { lineStyle: { color: "#f0f0f0" } }, axisLine: { show: false } },
                tooltip: { trigger: "axis", formatter: function (p) { return p[0].axisValue + "<br/>" + p.map(function (x) { return x.marker + " " + x.seriesName + ": " + fmt(x.value); }).join("<br/>"); } },
                series: [
                    { name: "FY Outlook", type: "bar", data: aData.map(function (d) { return d.fyOutlook; }), barWidth: 50, z: 1, itemStyle: { color: "#1565c0" }, label: { show: true, position: "top", color: "#333", fontSize: 9, formatter: function (p) { return fmt(p.value); } } },
                    { name: "YTD",        type: "bar", data: aData.map(function (d) { return d.ytd; }),       barWidth: 35, barGap: "-100%", z: 2, itemStyle: { color: "#1e88e5" }, label: { show: true, position: "top", color: "#333", fontSize: 9, formatter: function (p) { return fmt(p.value); } } },
                    { name: "FY Budget",  type: "bar", data: aData.map(function (d) { return d.fyBudget; }),  barWidth: 20, barGap: "-100%", z: 3, itemStyle: { color: "#90caf9" }, label: { show: false } }
                ]
            });

            window.addEventListener("resize", function () { oChart.resize(); });
        }
    });
});

